# ── Infraestrutura ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@db:5432/consulta_margem
REDIS_URL=redis://redis:6379/0

# ── Autenticação JWT ──────────────────────────────────────────────────────────
SECRET_KEY=gere_uma_chave_forte_aqui_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Criptografia de Credenciais (AES-256-GCM) ─────────────────────────────────
# OBRIGATÓRIO! Gere com: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=gere_com_comando_acima_32bytes_base64=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=30

# ── AkiCapital (login padrão — opcional, pode ser sobrescrito por credencial) ─
AKICAPITAL_URL=https://akipromotora.app/WebAutorizador/Login/AC.UI.LOGIN.aspx?FISession=7ed4824df157
AKICAPITAL_LOGIN=
AKICAPITAL_SENHA=

# ── GridSoftware / Roraima ────────────────────────────────────────────────────
GRID_URL=https://consignado.gridsoftware.com.br/grid/login.seam?
GRID_LOGIN=
GRID_SENHA=


# ── Prefeitura Boa Vista / RF1 ───────────────────────────────────────────────
BOAVISTA_URL=https://boavista.rf1consig.com.br/SGConsignataria/ConsigAcessoUsuarioLogar.aspx
BOAVISTA_LOGIN=
BOAVISTA_SENHA=
BOAVISTA_ORGAO=
BOAVISTA_CODIGO_SEGURANCA=

# ── 2Captcha (para resolver reCAPTCHA do GridSoftware) ────────────────────────
TWOCAPTCHA_API_KEY=sua_chave_2captcha
TWOCAPTCHA_TIMEOUT_S=120
TWOCAPTCHA_POLL_INTERVAL_S=5

# ── Sessões Playwright ────────────────────────────────────────────────────────
SESSION_DIR=/tmp/pw_sessions
